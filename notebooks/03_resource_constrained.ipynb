   "source": [
    "## Threshold Tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d6faecf",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.metrics import precision_recall_curve\n",
    "\n",
    "# grab predicted probabilities from the best rc model\n",
    "y_prob_rc = final_rc_pipe.predict_proba(X_te_rc_best)[:, 1]\n",
    "\n",
    "# precision-recall curve + f1 at each threshold\n",
    "precisions, recalls, thresholds = precision_recall_curve(y_test, y_prob_rc)\n",
    "f1_scores = 2 * (precisions * recalls) / (precisions + recalls + 1e-8)\n",
    "\n",
    "# --- plot: precision / recall / f1 vs threshold + pr curve ---\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(thresholds, precisions[:-1], \"b-\", label=\"Precision\", linewidth=2)\n",
    "axes[0].plot(thresholds, recalls[:-1],    \"r-\", label=\"Recall\",    linewidth=2)\n",
    "axes[0].plot(thresholds, f1_scores[:-1],  \"g-\", label=\"F1\",        linewidth=2)\n",
    "axes[0].axvline(x=0.5, color=\"gray\", linestyle=\"--\", alpha=0.7, label=\"default (0.5)\")\n",
    "axes[0].set_xlabel(\"Threshold\")\n",
    "axes[0].set_ylabel(\"Score\")\n",
    "axes[0].set_title(\"Precision, Recall, F1 vs Threshold\")\n",
    "axes[0].legend()\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "axes[1].plot(recalls, precisions, \"b-\", linewidth=2)\n",
    "axes[1].set_xlabel(\"Recall\")\n",
    "axes[1].set_ylabel(\"Precision\")\n",
    "axes[1].set_title(\"Precision-Recall Curve\")\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"../reports/figures/rc_threshold_curves.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "\n",
    "# --- threshold sweep table ---\n",
    "print(\"\\n=== threshold analysis ===\")\n",
    "print(f\"{'threshold':>10} {'recall':>8} {'precision':>10} {'f1':>8}\")\n",
    "print(\"-\" * 42)\n",
    "\n",
    "for thresh in np.arange(0.1, 0.9, 0.05):\n",
    "    y_pred_thresh = (y_prob_rc >= thresh).astype(int)\n",
    "    r  = recall_score(y_test, y_pred_thresh, pos_label=1, zero_division=0)\n",
    "    pr = precision_score(y_test, y_pred_thresh, pos_label=1, zero_division=0)\n",
    "    f1 = f1_score(y_test, y_pred_thresh, pos_label=1, zero_division=0)\n",
    "    # flag thresholds near the default range as potential optimals\n",
    "    marker = \" <- check\" if 0.30 <= thresh <= 0.55 else \"\"\n",
    "    print(f\"{thresh:>10.2f} {r:>8.4f} {pr:>10.4f} {f1:>8.4f}{marker}\")"
   ]
