    {
      "cell_type": "markdown",
      "source": [
        "##Hyperparameter Tuning (Optuna)"
      ],
      "metadata": {
        "id": "3IL8a8FqXVUI"
      },
      "id": "3IL8a8FqXVUI"
    },
    {
      "cell_type": "code",
      "source": [
        "FE_NAME = \"FE-B-PP (RC)\"\n",
        "X_train = X_train_B_PP_rc.copy()\n",
        "X_test  = X_test_B_PP_rc.copy()\n",
        "y_train = y_train.copy()\n",
        "y_test  = y_test.copy()\n",
        "\n",
        "print(f\"Tuning Gradient Boosting untuk: {FE_NAME} + SMOTENC + No Scaling\")\n",
        "print(f\"Features : {X_train.shape[1]} | Train rows: {X_train.shape[0]}\")\n",
        "\n",
        "# CV Setup\n",
        "N_SPLITS = 10\n",
        "SKF = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=42)\n",
        "\n",
        "SCORING = {\n",
        "    \"recall_1\":    make_scorer(recall_score,    pos_label=1, zero_division=0),\n",
        "    \"precision_1\": make_scorer(precision_score, pos_label=1, zero_division=0),\n",
        "    \"f1_1\":        make_scorer(f1_score,        pos_label=1, zero_division=0),\n",
        "    \"accuracy\":    \"accuracy\"\n",
        "}\n",
        "\n",
        "def objective(trial):\n",
        "    params = {\n",
        "        'n_estimators':      trial.suggest_int('n_estimators', 100, 600),\n",
        "        'learning_rate':     trial.suggest_float('learning_rate', 0.01, 0.3, log=True),\n",
        "        'max_depth':         trial.suggest_int('max_depth', 3, 12),\n",
        "        'min_samples_split': trial.suggest_int('min_samples_split', 2, 10),\n",
        "        'min_samples_leaf':  trial.suggest_int('min_samples_leaf', 1, 6),\n",
        "        'subsample':         trial.suggest_float('subsample', 0.6, 1.0),\n",
        "        'max_features':      trial.suggest_categorical('max_features', ['sqrt', 'log2', None]),\n",
        "    }\n",
        "\n",
        "    binary_mask = [col in binary_cols for col in X_train.columns]\n",
        "\n",
        "    pipe = ImbPipeline([\n",
        "        ('resampler', SMOTENC(categorical_features=binary_mask, random_state=42)),\n",
        "        ('clf', GradientBoostingClassifier(random_state=42, **params))\n",
        "    ])\n",
        "\n",
        "    cv_results = cross_validate(\n",
        "        pipe, X_train, y_train,\n",
        "        cv=SKF,\n",
        "        scoring=SCORING,\n",
        "        n_jobs=-1\n",
        "    )\n",
        "\n",
        "    mean_recall = cv_results['test_recall_1'].mean()\n",
        "    return mean_recall\n",
        "\n",
        "print(\"Optuna Tuning Gradient Boosting - 60 trials\")\n",
        "\n",
        "study = optuna.create_study(\n",
        "    direction=\"maximize\",\n",
        "    sampler=optuna.samplers.TPESampler(seed=42),\n",
        "    pruner=optuna.pruners.MedianPruner(n_startup_trials=10, n_warmup_steps=5)\n",
        ")\n",
        "\n",
        "study.optimize(objective, n_trials=60, timeout=1800)\n",
        "\n",
        "print(\"\\n BEST TRIAL RESULTS:\")\n",
        "print(f\"Best Recall_1 (CV) : {study.best_value:.5f}\")\n",
        "print(\"Best hyperparameters:\")\n",
        "for key, value in study.best_params.items():\n",
        "    print(f\"   {key:20}: {value}\")\n",
        "\n",
        "best_params = study.best_params\n",
        "\n",
        "binary_mask = [col in binary_cols for col in X_train.columns]\n",
        "\n",
        "best_pipe = ImbPipeline([\n",
        "    ('resampler', SMOTENC(categorical_features=binary_mask, random_state=42)),\n",
        "    ('clf', GradientBoostingClassifier(random_state=42, **best_params))\n",
        "])\n",
        "\n",
        "print(\"\\nFitting best model on full training set...\")\n",
        "best_pipe.fit(X_train, y_train)\n",
        "\n",
        "y_pred = best_pipe.predict(X_test)\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"CLASSIFICATION REPORT — TEST SET (FE-B-PP + Best Gradient Boosting)\")\n",
        "print(\"=\"*70)\n",
        "print(classification_report(y_test, y_pred, target_names=[\"Low Risk\", \"High Risk\"]))\n",
        "\n",
        "# Confusion Matrix\n",
        "cm = confusion_matrix(y_test, y_pred)\n",
        "disp = ConfusionMatrixDisplay(cm, display_labels=[\"Low Risk\", \"High Risk\"])\n",
        "disp.plot(cmap=\"Blues\")\n",
        "plt.title(\"Confusion Matrix - Best Gradient Boosting after Optuna\")\n",
        "plt.show()\n"
      ],
