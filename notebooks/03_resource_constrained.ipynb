      "cell_type": "markdown",
      "id": "5f7d466a",
      "metadata": {
        "id": "5f7d466a"
      },
      "source": [
        "## Feature Engineering"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "7d047cb6",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "7d047cb6",
        "outputId": "226d8b1b-4730-4471-f81f-bd71bf4f60be"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "train: 934 | test: 234\n"
          ]
        }
      ],
      "source": [
        "df[\"Is_Fever\"] = (df[\"Body Temp\"] > 99).astype(int)\n",
        "\n",
        "binary_cols  = [col for col in df.select_dtypes(include=[np.number]).columns\n",
        "                if df[col].dropna().isin([0, 1]).all()]\n",
        "numeric_cols = [col for col in df.select_dtypes(include=[np.number]).columns\n",
        "                if col not in binary_cols]\n",
        "\n",
        "feature_cols = numeric_cols + binary_cols\n",
        "X = df[feature_cols]\n",
        "y = df[\"Risk Level\"].map({\"High\": 1, \"Low\": 0})\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.2, random_state=RS, stratify=y\n",
        ")\n",
        "print(f\"train: {X_train.shape[0]} | test: {X_test.shape[0]}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "9cd8e72c",
      "metadata": {
        "id": "9cd8e72c"
      },
      "source": [
        "## Feature Engineering Variants (RC versions)\n",
        "- **FE-A (RC)** — all features minus RC drops, keeps `Body Temp`  \n",
        "- **FE-B (RC)** — also drops `Body Temp`  \n",
        "- **FE-A-PP (RC)** — adds `Pulse Pressure` + `MAP`, keeps `Body Temp`  \n",
        "- **FE-B-PP (RC)** — adds `Pulse Pressure` + `MAP`, drops `Body Temp`"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "b4a8e795",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "b4a8e795",
        "outputId": "c22fecef-7e1b-48de-db5c-4f2df56a7b2c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "FE-A (RC): train (934, 8), test (234, 8)  features: ['Age', 'Systolic BP', 'Diastolic', 'Body Temp', 'BMI', 'Heart Rate', 'Previous Complications', 'Is_Fever']\n",
            "FE-B (RC): train (934, 7), test (234, 7)  features: ['Age', 'Systolic BP', 'Diastolic', 'BMI', 'Heart Rate', 'Previous Complications', 'Is_Fever']\n",
            "FE-A-PP (RC): train (934, 10), test (234, 10)  features: ['Age', 'Systolic BP', 'Diastolic', 'Body Temp', 'BMI', 'Heart Rate', 'Pulse Pressure', 'MAP', 'Previous Complications', 'Is_Fever']\n",
            "FE-B-PP (RC): train (934, 9), test (234, 9)  features: ['Age', 'Systolic BP', 'Diastolic', 'BMI', 'Heart Rate', 'Pulse Pressure', 'MAP', 'Previous Complications', 'Is_Fever']\n"
          ]
        }
      ],
      "source": [
        "RC_DROP_COLS = [\"BS\", \"Gestational Diabetes\", \"Preexisting Diabetes\", \"Mental Health\"]\n",
        "\n",
        "# FE-A (RC)\n",
        "X_train_A_rc = X_train.drop(columns=[c for c in RC_DROP_COLS if c in X_train.columns]).copy()\n",
        "X_test_A_rc  = X_test.drop(columns=[c for c in RC_DROP_COLS if c in X_test.columns]).copy()\n",
        "\n",
        "# FE-B (RC)\n",
        "X_train_B_rc = X_train_A_rc.drop(columns=[\"Body Temp\"], errors=\"ignore\").copy()\n",
        "X_test_B_rc  = X_test_A_rc.drop(columns=[\"Body Temp\"],  errors=\"ignore\").copy()\n",
        "\n",
        "df_pp_rc = df.copy()\n",
        "df_pp_rc = df_pp_rc.drop(columns=[\"Gestational Diabetes\"], errors=\"ignore\")\n",
        "df_pp_rc[\"Pulse Pressure\"] = df_pp_rc[\"Systolic BP\"] - df_pp_rc[\"Diastolic\"]\n",
        "df_pp_rc[\"MAP\"] = (df_pp_rc[\"Systolic BP\"] + 2 * df_pp_rc[\"Diastolic\"]) / 3\n",
        "\n",
        "pp_rc_binary  = [c for c in df_pp_rc.select_dtypes(include=[np.number]).columns\n",
        "                 if df_pp_rc[c].dropna().isin([0, 1]).all()]\n",
        "pp_rc_numeric = [c for c in df_pp_rc.select_dtypes(include=[np.number]).columns\n",
        "                 if c not in pp_rc_binary]\n",
        "pp_rc_feat    = pp_rc_numeric + pp_rc_binary\n",
        "\n",
        "X_pp_rc = df_pp_rc[pp_rc_feat]\n",
        "X_train_pp_rc, X_test_pp_rc, _, _ = train_test_split(\n",
        "    X_pp_rc, y, test_size=0.2, random_state=RS, stratify=y\n",
        ")\n",
        "\n",
        "# FE-A-PP (RC) & FE-B-PP (RC)\n",
        "rc_drop_in_pp = [c for c in RC_DROP_COLS if c in X_train_pp_rc.columns]\n",
        "X_train_A_PP_rc = X_train_pp_rc.drop(columns=rc_drop_in_pp, errors=\"ignore\").copy()\n",
        "X_test_A_PP_rc  = X_test_pp_rc.drop(columns=rc_drop_in_pp,  errors=\"ignore\").copy()\n",
        "\n",
        "X_train_B_PP_rc = X_train_A_PP_rc.drop(columns=[\"Body Temp\"], errors=\"ignore\").copy()\n",
        "X_test_B_PP_rc  = X_test_A_PP_rc.drop(columns=[\"Body Temp\"],  errors=\"ignore\").copy()\n",
        "\n",
        "FE_RC = {\n",
        "    \"FE-A (RC)\":    (X_train_A_rc,    X_test_A_rc),\n",
        "    \"FE-B (RC)\":    (X_train_B_rc,    X_test_B_rc),\n",
        "    \"FE-A-PP (RC)\": (X_train_A_PP_rc, X_test_A_PP_rc),\n",
        "    \"FE-B-PP (RC)\": (X_train_B_PP_rc, X_test_B_PP_rc),\n",
        "}\n",
        "\n",
        "for name, (tr, te) in FE_RC.items():\n",
        "    print(f\"{name}: train {tr.shape}, test {te.shape}  features: {tr.columns.tolist()}\")"
      ]
    },
