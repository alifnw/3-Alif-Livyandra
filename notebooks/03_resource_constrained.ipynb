      "source": [
        "results = []\n",
        "\n",
        "selected_models = BASE_MODELS.copy()\n",
        "\n",
        "total = len(FE_RC) * 2 * 4 * 2 * len(selected_models)\n",
        "print(f\"Total kombinasi yang akan dijalankan: {total}\")\n",
        "\n",
        "counter = 0\n",
        "\n",
        "for fe_name, (Xtr, Xte) in FE_RC.items():\n",
        "    resamplers_dict = get_resamplers(Xtr)\n",
        "\n",
        "    for scale_name, do_scale in [(\"Standard\", True), (\"None\", False)]:\n",
        "        for res_name, resampler in resamplers_dict.items():\n",
        "            for cv_name, cv_obj in [(\"StratifiedKFold\", SKF), (\"KFold\", KF)]:\n",
        "                for mdl_name, base_model in selected_models.items():\n",
        "\n",
        "                    counter += 1\n",
        "                    pipe = build_rc_no_pca_pipeline(base_model, scale=do_scale, resampler=resampler)\n",
        "\n",
        "                    try:\n",
        "                        cv_results = cross_validate(\n",
        "                            pipe, Xtr, y_train,\n",
        "                            cv=cv_obj,\n",
        "                            scoring=SCORING,\n",
        "                            n_jobs=-1\n",
        "                        )\n",
        "\n",
        "                        row = {\n",
        "                            \"FE\": fe_name,\n",
        "                            \"Scaling\": scale_name,\n",
        "                            \"Resampler\": res_name,\n",
        "                            \"CV_Type\": cv_name,\n",
        "                            \"Model\": mdl_name,\n",
        "                            \"Recall_1\":    round(cv_results[\"test_recall_1\"].mean(), 4),\n",
        "                            \"Precision_1\": round(cv_results[\"test_precision_1\"].mean(), 4),\n",
        "                            \"F1_1\":        round(cv_results[\"test_f1_1\"].mean(), 4),\n",
        "                            \"Accuracy\":    round(cv_results[\"test_accuracy\"].mean(), 4)\n",
        "                        }\n",
        "                        results.append(row)\n",
        "\n",
        "                        print(f\"[{counter:3d}/{total}] {fe_name:12} | {scale_name:8} | {res_name:10} | \"\n",
        "                              f\"{cv_name:15} | {mdl_name:12} → Rec={row['Recall_1']:.4f} \"\n",
        "                              f\"F1={row['F1_1']:.4f} Prec={row['Precision_1']:.4f} Acc={row['Accuracy']:.4f}\")\n",
        "\n",
        "                    except Exception as e:\n",
        "                        print(f\"[{counter:3d}/{total}] ERROR pada {fe_name} | {res_name} | {mdl_name} → {str(e)[:80]}\")\n",
        "                        continue\n"
      ]
    },
