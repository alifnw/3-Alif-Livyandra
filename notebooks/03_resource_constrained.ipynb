        "def get_resamplers(X_current):\n",
        "    binary_mask = [col in binary_cols for col in X_current.columns]\n",
        "    return {\n",
        "        \"None\":       None,\n",
        "        \"SMOTE\":      SMOTE(random_state=RS),\n",
        "        \"SMOTENC\":    SMOTENC(categorical_features=binary_mask, random_state=RS),\n",
        "        \"SMOTETomek\": SMOTETomek(random_state=RS)\n",
        "    }\n",
        "\n",
        "def build_rc_no_pca_pipeline(model, scale=True, resampler=None):\n",
        "    clf = copy.deepcopy(model)\n",
        "    steps = []\n",
        "    if scale:\n",
        "        steps.append((\"scaler\", StandardScaler()))\n",
        "    if resampler is not None:\n",
        "        steps.append((\"resampler\", resampler))\n",
        "    steps.append((\"clf\", clf))\n",
        "    return ImbPipeline(steps)"
      ]
    },
