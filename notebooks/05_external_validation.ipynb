    "records_2 = []\n",
    "for mdl_name, mdl in BASE_MODELS.items():\n",
    "    for res_name in [\"SMOTENC\", \"SMOTE\", \"SMOTETomek\"]:\n",
    "        for scale_name, do_scale in [(\"Standard\", True), (\"None\", False)]:\n",
    "            try:\n",
    "                pipe = build_pipeline(mdl, X_train_2, resampler_name=res_name, scale=do_scale)\n",
    "                cv   = cross_validate(pipe, X_train_2, y_train, cv=SKF,\n",
    "                                      scoring=SCORING, n_jobs=-1)\n",
    "                records_2.append({\n",
    "                    \"Model\"      : mdl_name,\n",
    "                    \"Resampler\"  : res_name,\n",
    "                    \"Scaling\"    : scale_name,\n",
    "                    \"Recall_1\"   : round(cv[\"test_recall_1\"].mean(), 4),\n",
    "                    \"Precision_1\": round(cv[\"test_precision_1\"].mean(), 4),\n",
    "                    \"F1_1\"       : round(cv[\"test_f1_1\"].mean(), 4),\n",
    "                    \"Accuracy\"   : round(cv[\"test_accuracy\"].mean(), 4),\n",
    "                })\n",
    "            except Exception as e:\n",
    "                pass\n",
    "\n",
    "lb2 = pd.DataFrame(records_2).sort_values(\"Recall_1\", ascending=False).reset_index(drop=True)\n",
    "print(\"Dataset 2 Pipeline — CV Leaderboard (Top 10):\")\n",
    "display(lb2.head(10))\n",
    "\n"
   ]
