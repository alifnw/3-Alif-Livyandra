   "id": "7de7cde7",
   "metadata": {},
   "source": [
    "# 05 — External Dataset Validation\n",
    "Option 1: retrain on shared features only per external dataset.\n",
    "No fabricated values — each pipeline uses only columns present in both training data and the external dataset.\n",
    "\n",
    "- **Pipeline A** — validated against Dataset 1 (UCI, 678 rows after mid risk removal)\n",
    "- **Pipeline B** — validated against Dataset 2 (includes BMI)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "54758800",
   "metadata": {},
   "outputs": [],
   "source": [
    "import warnings; warnings.filterwarnings(\"ignore\")\n",
    "import copy\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from sklearn.model_selection import train_test_split, StratifiedKFold, cross_validate\n",
    "from sklearn.pipeline        import Pipeline as SkPipeline\n",
    "from sklearn.preprocessing   import StandardScaler\n",
    "from sklearn.linear_model    import LogisticRegression\n",
    "from sklearn.tree            import DecisionTreeClassifier\n",
    "from sklearn.ensemble        import (RandomForestClassifier, GradientBoostingClassifier,\n",
    "                                     ExtraTreesClassifier)\n",
    "from sklearn.svm             import SVC\n",
    "from sklearn.metrics         import (make_scorer, accuracy_score, precision_score,\n",
    "                                     recall_score, f1_score, classification_report,\n",
    "                                     confusion_matrix, ConfusionMatrixDisplay, roc_auc_score)\n",
    "from xgboost                 import XGBClassifier\n",
    "from lightgbm                import LGBMClassifier\n",
    "from imblearn.pipeline       import Pipeline as ImbPipeline\n",
    "from imblearn.over_sampling  import SMOTE, SMOTENC\n",
    "from imblearn.combine        import SMOTETomek\n",
    "from imblearn.over_sampling  import SMOTENC\n",
    "\n",
    "import os\n",
    "os.makedirs(\"../reports/figures\", exist_ok=True)\n",
    "\n",
    "RS       = 42\n",
    "N_SPLITS = 10\n",
    "SKF      = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=RS)\n",
    "\n",
    "SCORING = {\n",
    "    \"accuracy\"   : make_scorer(accuracy_score),\n",
    "    \"precision_1\": make_scorer(precision_score, pos_label=1, zero_division=0),\n",
    "    \"recall_1\"   : make_scorer(recall_score,    pos_label=1, zero_division=0),\n",
    "    \"f1_1\"       : make_scorer(f1_score,        pos_label=1, zero_division=0),\n",
    "}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1d28c52e",
   "metadata": {},
   "source": [
    "## Training Data — Rebuild Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "4f618fab",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "training features: ['Age', 'Systolic BP', 'Diastolic', 'BS', 'Body Temp', 'BMI', 'Heart Rate', 'Previous Complications', 'Preexisting Diabetes', 'Gestational Diabetes', 'Mental Health', 'Is_Fever']\n",
      "train: 934 rows  |  test: 234 rows\n"
     ]
    }
   ],
   "source": [
    "df = pd.read_csv('../data/processed/maternal_health_cleaned.csv')\n",
    "\n",
    "df[\"Is_Fever\"] = (df[\"Body Temp\"] > 99).astype(int)\n",
    "\n",
    "binary_cols  = [col for col in df.select_dtypes(include=[np.number]).columns\n",
    "                if df[col].dropna().isin([0, 1]).all()]\n",
    "numeric_cols = [col for col in df.select_dtypes(include=[np.number]).columns\n",
    "                if col not in binary_cols]\n",
    "\n",
    "feature_cols = numeric_cols + binary_cols\n",
    "X = df[feature_cols]\n",
    "y = df[\"Risk Level\"].map({\"High\": 1, \"Low\": 0})\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.2, random_state=RS, stratify=y\n",
    ")\n",
    "\n",
    "print(f\"training features: {X_train.columns.tolist()}\")\n",
    "print(f\"train: {X_train.shape[0]} rows  |  test: {X_test.shape[0]} rows\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c69af928",
   "metadata": {},
   "source": [
    "## Model Registry"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "a86af169",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "8 models registered\n"
     ]
    }
   ],
   "source": [
    "BASE_MODELS = {\n",
    "    \"Logistic Regression\": LogisticRegression(random_state=RS, max_iter=1000),\n",
    "    \"Decision Tree\"      : DecisionTreeClassifier(random_state=RS),\n",
    "    \"Random Forest\"      : RandomForestClassifier(random_state=RS, n_jobs=-1),\n",
    "    \"Gradient Boosting\"  : GradientBoostingClassifier(random_state=RS),\n",
    "    \"XGBoost\"            : XGBClassifier(random_state=RS, verbosity=0, eval_metric=\"logloss\", n_jobs=-1),\n",
    "    \"LightGBM\"           : LGBMClassifier(random_state=RS, verbose=-1, n_jobs=-1),\n",
    "    \"SVM\"                : SVC(random_state=RS, probability=True),\n",
    "    \"Extra Trees\"        : ExtraTreesClassifier(random_state=RS, n_jobs=-1),\n",
    "}\n",
    "print(f\"{len(BASE_MODELS)} models registered\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7e3ad101",
   "metadata": {},
   "source": [
    "## Pipeline Builder"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "f9fb8b38",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_cat_indices(X):\n",
    "    return [i for i, col in enumerate(X.columns) if X[col].nunique() < 5]\n",
    "\n",
    "\n",
    "def build_pipeline(model, X_tr, resampler_name=\"SMOTENC\", scale=True):\n",
    "    clf = copy.deepcopy(model)\n",
    "    cat_idx = get_cat_indices(X_tr)\n",
    "\n",
    "    if resampler_name == \"SMOTENC\" and cat_idx:\n",
    "        resampler = SMOTENC(categorical_features=cat_idx, random_state=RS)\n",
    "    elif resampler_name == \"SMOTE\":\n",
    "        resampler = SMOTE(random_state=RS)\n",
    "    elif resampler_name == \"SMOTETomek\":\n",
    "        resampler = SMOTETomek(random_state=RS)\n",
    "    else:\n",
    "        resampler = SMOTE(random_state=RS)\n",
    "\n",
    "    steps = []\n",
    "    if scale:\n",
    "        steps.append((\"scaler\", StandardScaler()))\n",
    "    steps.append((\"resampler\", resampler))\n",
    "    steps.append((\"clf\", clf))\n",
    "    return ImbPipeline(steps)\n",
    "\n",
    "\n",
    "def evaluate_external(pipe, X_tr, X_ext, y_tr, y_ext, label):\n",
    "    pipe.fit(X_tr, y_tr)\n",
    "    y_pred = pipe.predict(X_ext)\n",
    "    report = classification_report(y_ext, y_pred, target_names=[\"Low Risk\", \"High Risk\"],\n",
    "                                   output_dict=True)\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"{label}\")\n",
    "    print(f\"{'='*60}\")\n",
    "    print(classification_report(y_ext, y_pred, target_names=[\"Low Risk\", \"High Risk\"]))\n",
    "    return y_pred, report"
   ]
  },
