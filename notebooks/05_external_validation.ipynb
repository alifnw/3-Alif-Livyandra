   "source": [
    "df_ext1 = pd.read_csv('../data/external/maternal.csv')\n",
    "\n",
    "col_rename_1 = {\n",
    "    \"SystolicBP\" : \"Systolic BP\",\n",
    "    \"DiastolicBP\": \"Diastolic\",\n",
    "    \"BodyTemp\"   : \"Body Temp\",\n",
    "    \"HeartRate\"  : \"Heart Rate\",\n",
    "    \"RiskLevel\"  : \"Risk Level\",\n",
    "}\n",
    "df_ext1 = df_ext1.rename(columns=col_rename_1)\n",
    "df_ext1[\"Risk Level\"] = df_ext1[\"Risk Level\"].str.strip().str.lower()\n",
    "df_ext1 = df_ext1[df_ext1[\"Risk Level\"].isin([\"high risk\", \"low risk\"])].copy()\n",
    "df_ext1[\"Risk Level\"] = df_ext1[\"Risk Level\"].map({\"high risk\": 1, \"low risk\": 0})\n",
    "df_ext1[\"Is_Fever\"] = (df_ext1[\"Body Temp\"] > 99).astype(int)\n",
    "\n",
    "print(f\"Dataset 1 rows after mid risk removal: {len(df_ext1)}\")\n",
    "print(f\"High Risk: {df_ext1['Risk Level'].sum()} | Low Risk: {(df_ext1['Risk Level']==0).sum()}\")\n",
    "print(f\"Columns available: {df_ext1.columns.tolist()}\")"
   ]
  },
