      "Shared features   : ['Age', 'Systolic BP', 'Diastolic', 'BS', 'Body Temp', 'Heart Rate', 'Is_Fever']\n",
      "Dropped from train: ['BMI', 'Previous Complications', 'Preexisting Diabetes', 'Gestational Diabetes', 'Mental Health']\n"
     ]
    }
   ],
   "source": [
    "# shared features: intersection of training data and dataset 1\n",
    "SHARED_COLS_1 = [c for c in X_train.columns if c in df_ext1.columns]\n",
    "print(f\"Training expects  : {X_train.columns.tolist()}\")\n",
    "print(f\"Dataset 1 has     : {df_ext1.columns.tolist()}\")\n",
    "print(f\"Shared features   : {SHARED_COLS_1}\")\n",
