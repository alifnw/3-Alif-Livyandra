    "\n",
    "X_train_1 = X_train[SHARED_COLS_1].copy()\n",
    "X_ext1    = df_ext1[SHARED_COLS_1].copy()\n",
    "y_ext1    = df_ext1[\"Risk Level\"].copy()"
   ]
